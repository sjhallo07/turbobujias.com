{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Technical automotive part in the catalog",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Part number / Reference ID" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "specs": { "type": "object" },
        "stock": { "type": "number" },
        "oeReference": { "type": "string" },
        "tags": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Custom labels like New Arrival or Best Seller"
        },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "name", "brand", "category", "price", "image"]
    },
    "Partner": {
      "title": "Partner",
      "description": "Authorized brand, store or technical workshop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "type": { "type": "string", "enum": ["brand", "store", "workshop"] },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "isPromoted": { "type": "boolean" },
        "socials": { 
          "type": "object",
          "properties": {
            "instagram": { "type": "string" },
            "whatsapp": { "type": "string" },
            "web": { "type": "string" }
          }
        },
        "updatedAt": { "type": "object" }
      },
      "required": ["name", "type", "location"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a user's chat session",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "bot"] },
        "content": { "type": "string" },
        "recommendedProductId": { "type": "string" },
        "timestamp": { "type": "object" },
        "attachments": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["role", "content", "timestamp"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation session containing multiple messages",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" },
        "lastMessage": { "type": "string" }
      },
      "required": ["title", "createdAt", "updatedAt"]
    },
    "UserMemory": {
      "title": "User Memory",
      "description": "Strategic technical summary of user's car, needs, and history",
      "type": "object",
      "properties": {
        "summary": { "type": "string", "description": "Consolidated mechanical profile" },
        "preferences": { "type": "array", "items": { "type": "string" } },
        "vehicleInfo": { "type": "string" },
        "lastUpdate": { "type": "object" }
      }
    },
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "lastLogin": { "type": "object" },
        "createdAt": { "type": "object" }
      },
      "required": ["uid", "email", "role"]
    },
    "Admin": {
      "title": "Admin",
      "description": "UID-linked admin record",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      }
    },
    "Review": {
      "title": "Product Review",
      "description": "User review for a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["productId", "userId", "rating", "createdAt"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Record of administrative actions",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "adminEmail": { "type": "string" },
        "action": { "type": "string", "enum": ["CREATE_PRODUCT", "UPDATE_PRODUCT", "DELETE_PRODUCT", "SYNC_SUPABASE", "IMPORT_CSV", "USER_ROLE_CHANGE"] },
        "targetId": { "type": "string" },
        "targetName": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "object" }
      },
      "required": ["adminId", "action", "timestamp"]
    }
  },
  "firestore": {
    "products": { "schema": "Product", "description": "Inventory of parts" },
    "partners": { "schema": "Partner", "description": "Network of technical places" },
    "users": { "schema": "User", "description": "User profiles" },
    "users/{userId}/memory": { "schema": "UserMemory", "description": "Strategic technical memory of the user" },
    "users/{userId}/sessions": { "schema": "ChatSession", "description": "User conversation sessions" },
    "users/{userId}/sessions/{sessionId}/messages": { "schema": "ChatMessage", "description": "Messages within a session" },
    "products/{productId}/reviews": { "schema": "Review", "description": "User reviews for products" },
    "admins": { "schema": "Admin", "description": "Global admins list" },
    "auditLogs": { "schema": "AuditLog", "description": "Registry of admin activities" }
  }
}
