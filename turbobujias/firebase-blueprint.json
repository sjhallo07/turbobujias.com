{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and authentication data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] }
      }
    },
    "Purchase": {
      "title": "Purchase Order",
      "description": "Records of customer purchases.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "ChatSession": {
      "title": "Chatbot Learning",
      "description": "Chat history for chatbot learning/context.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "messages": { "type": "array" }
      }
    },
    "BulkImport": {
      "title": "Bulk Import Log",
      "description": "Status of Excel/CSV imports.",
      "type": "object",
      "properties": {
        "filename": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}": { "schema": "User", "description": "User profiles." },
    "orders/{orderId}": { "schema": "Purchase", "description": "Purchase records." },
    "chat_memory/{sessionId}": { "schema": "ChatSession", "description": "Chatbot context." },
    "bulk_imports/{importId}": { "schema": "BulkImport", "description": "Import logs." }
  }
}